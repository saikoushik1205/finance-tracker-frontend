PORT=3000

# MongoDB Connection (use MONGO_URI)
# For local: mongodb://localhost:27017/fintrack
# For MongoDB Atlas: mongodb://username:password@host1:27017,host2:27017,host3:27017/dbname?ssl=true&authSource=admin&retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/fintrack

# JWT Configuration (Generate with: node scripts/generateSecret.js)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=12h

# Environment (development | production)
NODE_ENV=development

# Frontend URL for CORS
# Local: http://localhost:4200
# Production: https://your-frontend-url.vercel.app
FRONTEND_URL=http://localhost:4200
